# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Model Provider: "openai" or "ollama"
MODEL_PROVIDER=openai

# Model Selection
OPENAI_MODEL=gpt-4o
OLLAMA_MODEL=llama3.2
EMBEDDING_MODEL=text-embedding-3-small

# Ollama Configuration (if using local models)
OLLAMA_BASE_URL=http://localhost:11434

# Database
DATABASE_URL=sqlite:///./support_agent.db

# Qdrant Vector Store (relative paths resolve under backend/ — see backend/rag/config_paths.py)
QDRANT_PATH=./qdrant_storage
# For remote Qdrant server (optional):
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your_qdrant_api_key

# MCP Server (TypeScript stdio — capstone_project/mcp_server: npm install; npx on PATH)
MCP_SERVER_PORT=3001
# Default: real MCP over stdio. Set USE_SIMULATED_MCP=1 for in-process Python stubs (no Node).
# USE_SIMULATED_MCP=1
# Legacy: USE_REAL_MCP=0 also selects simulation.

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=INFO

# Testing
TESTING=False
TEST_DATABASE_URL=sqlite:///:memory:
